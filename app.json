{
  "expo": {
    "name": "BookSome",
    "slug": "booksome",
    "version": "1.0.0",
    "scheme": "booksome",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.booksome.mobile",
      "infoPlist": {
        "NSCameraUsageDescription": "책 ISBN 바코드 스캔과 책 표지, 프로필, 리딩룸 이미지 업로드에 카메라를 사용합니다.",
        "NSPhotoLibraryUsageDescription": "책 표지, 프로필, 리딩룸 커버, 독서 모임 사진 업로드를 위해 사진 보관함에 접근합니다.",
        "NSLocationWhenInUseUsageDescription": "내 주변 독서 모임과 지역 기반 리딩룸을 추천하기 위해 위치를 사용합니다."
      }
    },
    "android": {
      "package": "app.booksome.mobile",
      "permissions": [
        "CAMERA",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "POST_NOTIFICATIONS"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#116653"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "책 ISBN 바코드 스캔과 책 표지 이미지 업로드에 카메라를 사용합니다."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "내 주변 독서 모임과 지역 기반 리딩룸을 추천하기 위해 위치를 사용합니다."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "책 표지, 프로필, 리딩룸 커버, 독서 모임 사진 업로드를 위해 사진 보관함에 접근합니다."
        }
      ],
      "expo-notifications"
    ]
  }
}
